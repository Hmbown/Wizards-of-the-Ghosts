{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardsoftheghosts.dev/catalog/gepa/schema/rubric-pack.schema.json",
  "title": "GEPA Rubric Pack",
  "description": "Schema for the raw category-level rubric packs that spell workspaces inherit and scripts/gepa_common.py normalizes for runtime use.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "category_slug",
    "category_title",
    "inherits_from",
    "schema_refs",
    "example_spell_slugs",
    "inheritance_contract",
    "response_contract",
    "benchmark_defaults",
    "deterministic_checks",
    "judge_criteria",
    "human_review",
    "review_escalation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "category_slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "category_title": {
      "type": "string",
      "minLength": 1
    },
    "inherits_from": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "schema_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmark_row",
        "scoring_contract",
        "rubric_pack"
      ],
      "properties": {
        "benchmark_row": {
          "type": "string",
          "const": "../schema/benchmark-row.schema.json"
        },
        "scoring_contract": {
          "type": "string",
          "const": "../schema/scoring-contract.json"
        },
        "rubric_pack": {
          "type": "string",
          "const": "../schema/rubric-pack.schema.json"
        }
      }
    },
    "example_spell_slugs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "inheritance_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spell_rubric_must_define",
        "spell_rubric_may_override",
        "spell_rubric_inherits_by_default"
      ],
      "properties": {
        "spell_rubric_must_define": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "spell_rubric_may_override": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "spell_rubric_inherits_by_default": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "response_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_sections",
        "required_deliverable_types",
        "required_guardrail_themes"
      ],
      "properties": {
        "required_sections": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "required_deliverable_types": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "required_guardrail_themes": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "benchmark_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_datasets",
        "minimum_rows",
        "coverage",
        "required_row_tags",
        "confusable_policy"
      ],
      "properties": {
        "required_datasets": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "enum": [
              "train",
              "eval",
              "confusables"
            ]
          },
          "uniqueItems": true
        },
        "minimum_rows": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "train",
            "eval",
            "confusables"
          ],
          "properties": {
            "train": {
              "type": "integer",
              "minimum": 1
            },
            "eval": {
              "type": "integer",
              "minimum": 1
            },
            "confusables": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "coverage": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "required_row_tags": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "confusable_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "must_test_against",
            "failure_modes_to_block"
          ],
          "properties": {
            "must_test_against": {
              "$ref": "#/$defs/nonEmptyStringArray"
            },
            "failure_modes_to_block": {
              "$ref": "#/$defs/nonEmptyStringArray"
            }
          }
        }
      }
    },
    "deterministic_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/deterministicCheck"
      }
    },
    "judge_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/judgeCriterion"
      }
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "triggers",
        "checklist"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "triggers": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "checklist": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "review_escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automerge_allowed_if"
      ],
      "properties": {
        "automerge_allowed_if": {
          "$ref": "#/$defs/stringArray"
        }
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "allOf": [
        {
          "$ref": "#/$defs/stringArray"
        }
      ]
    },
    "deterministicCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "kind",
        "weight"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "required_sections",
            "phrase_presence",
            "phrase_absence",
            "deliverable_presence"
          ]
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "phrases_any": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "phrases_all": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "required_sections"
              }
            }
          },
          "then": {
            "required": [
              "target"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "phrase_presence",
                  "deliverable_presence"
                ]
              }
            }
          },
          "then": {
            "anyOf": [
              {
                "required": [
                  "phrases_any"
                ]
              },
              {
                "required": [
                  "phrases_all"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "phrase_absence"
              }
            }
          },
          "then": {
            "required": [
              "phrases_any"
            ]
          }
        }
      ]
    },
    "judgeCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterion_id",
        "weight",
        "question"
      ],
      "properties": {
        "criterion_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "question": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
