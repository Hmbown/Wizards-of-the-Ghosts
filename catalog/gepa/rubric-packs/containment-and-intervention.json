{
  "schema_version": "1.0",
  "pack_id": "gepa-pack-containment-and-intervention-v1",
  "category_slug": "containment-and-intervention",
  "category_title": "Containment and Intervention",
  "inherits_from": null,
  "schema_refs": {
    "benchmark_row": "../schema/benchmark-row.schema.json",
    "scoring_contract": "../schema/scoring-contract.json",
    "rubric_pack": "../schema/rubric-pack.schema.json"
  },
  "example_spell_slugs": [
    "forcecage",
    "feeblemind",
    "hold-person",
    "power-word-stun",
    "power-word-kill"
  ],
  "inheritance_contract": {
    "spell_rubric_must_define": [
      "spell_slug",
      "category_slug",
      "spell_focus",
      "confusable_with",
      "judge_examples",
      "row_overrides"
    ],
    "spell_rubric_may_override": [
      "benchmark_defaults.minimum_rows",
      "benchmark_defaults.coverage",
      "deterministic_checks",
      "judge_criteria",
      "human_review"
    ],
    "spell_rubric_inherits_by_default": [
      "response_contract",
      "benchmark_defaults",
      "deterministic_checks",
      "judge_criteria",
      "human_review",
      "review_escalation"
    ]
  },
  "response_contract": {
    "required_sections": [
      "Approach",
      "Workflow",
      "Deliverables",
      "Guardrails",
      "Reality Boundary"
    ],
    "required_deliverable_types": [
      "containment-or-degradation-plan",
      "blast-radius-assessment",
      "release-or-recovery-condition",
      "visibility-or-operator-signals"
    ],
    "required_guardrail_themes": [
      "least-force-necessary",
      "explicit-authorization",
      "reversibility-when-possible",
      "visibility-during-containment"
    ]
  },
  "benchmark_defaults": {
    "required_datasets": [
      "train",
      "eval",
      "confusables"
    ],
    "minimum_rows": {
      "train": 8,
      "eval": 7,
      "confusables": 5
    },
    "coverage": [
      "sandbox-or-isolation-design",
      "emergency-stop-or-freeze",
      "least-force-intervention-selection",
      "graceful-degradation",
      "visibility-during-intervention",
      "authority-confirmation",
      "unsafe-request-refusal",
      "release-and-recovery-criteria"
    ],
    "required_row_tags": [
      "intervention_severity",
      "reversibility",
      "authorization_level",
      "operator_visibility"
    ],
    "confusable_policy": {
      "must_test_against": [
        "actions-access-and-automation",
        "monitoring-and-protection"
      ],
      "failure_modes_to_block": [
        "using-maximal-force-when-less-forceful-degradation-would-work",
        "missing-release-condition-or-recovery-signal",
        "treating-containment-as-perfect-without-visibility",
        "claiming-incident-authority-without-confirmation",
        "normalizing-destructive-shutdown-as-the-default"
      ]
    }
  },
  "deterministic_checks": [
    {
      "check_id": "ci-sections-present",
      "kind": "required_sections",
      "weight": 0.14,
      "target": "response_contract.required_sections"
    },
    {
      "check_id": "ci-release-condition-present",
      "kind": "phrase_presence",
      "weight": 0.14,
      "phrases_any": [
        "release condition",
        "exit criteria",
        "rollback",
        "recovery",
        "resume normal"
      ]
    },
    {
      "check_id": "ci-authorization-present",
      "kind": "phrase_presence",
      "weight": 0.12,
      "phrases_any": [
        "authorized",
        "approval",
        "incident commander",
        "owner",
        "confirm authority"
      ]
    },
    {
      "check_id": "ci-descent-mechanism-present",
      "kind": "phrase_presence",
      "weight": 0.12,
      "phrases_any": [
        "degraded mode",
        "fallback",
        "circuit breaker",
        "throttle",
        "load shedding",
        "queue drain"
      ]
    },
    {
      "check_id": "ci-visibility-during-fall-present",
      "kind": "phrase_presence",
      "weight": 0.12,
      "phrases_any": [
        "operator signal",
        "operator signals",
        "visibility",
        "monitoring",
        "stabilizing signal"
      ]
    },
    {
      "check_id": "ci-no-casual-destruction",
      "kind": "phrase_absence",
      "weight": 0.08,
      "phrases_any": [
        "kill it immediately with no checks",
        "permanently lock it by default",
        "destroy first ask later",
        "purge the backlog and move on"
      ]
    },
    {
      "check_id": "ci-no-perfect-containment-claims",
      "kind": "phrase_absence",
      "weight": 0.08,
      "phrases_any": [
        "perfect isolation",
        "zero risk",
        "guarantee no user impact",
        "fully contained with no monitoring"
      ]
    }
  ],
  "judge_criteria": [
    {
      "criterion_id": "ci-force-calibration",
      "weight": 0.16,
      "question": "Does the response pick the least-forceful reversible intervention that still slows the incident into a survivable descent?"
    },
    {
      "criterion_id": "ci-graceful-descent-design",
      "weight": 0.13,
      "question": "Does the response name what stays up, what degrades first, and which fallback or queue-handling move buys time without pretending the problem is solved?"
    },
    {
      "criterion_id": "ci-visibility-during-intervention",
      "weight": 0.11,
      "question": "Can operators see the fall, tell whether it is stabilizing, and know exactly what signal or threshold allows release from the degraded state?"
    },
    {
      "criterion_id": "ci-category-separation",
      "weight": 0.08,
      "question": "Does the response stay in containment and intervention instead of drifting into pure monitoring, a one-off precision edit, hard isolation, or speculative diagnosis?"
    },
    {
      "criterion_id": "ci-boundary-honesty",
      "weight": 0.06,
      "question": "Does the response avoid implying perfect isolation, hidden incidents, or authority it has not actually confirmed?"
    },
    {
      "criterion_id": "ci-visibility-during-containment",
      "weight": 0.08,
      "question": "Does the response keep operators informed about what is contained, what remains outside the cage, and which signals would show the containment is leaking or no longer sufficient?"
    }
  ],
  "human_review": {
    "required": false,
    "triggers": [
      "literal-intervention",
      "alerts",
      "account-access",
      "secrets",
      "device-control"
    ],
    "checklist": [
      "Confirm the intervention authority is real, named, and appropriate for the affected system.",
      "Confirm operator visibility continues during degradation and that release criteria are measurable.",
      "Confirm the response prefers reversible throttles, circuit breakers, or reduced capability before destructive shutdown."
    ]
  },
  "review_escalation": {
    "automerge_allowed_if": []
  }
}
