{
  "name": "wizardsoftheghosts",
  "version": "1.0.0",
  "private": true,
  "description": "An unofficial fan grimoire of Hermes Agent skills built from fantasy spell and skill names.",
  "license": "CC0-1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hmbown/Wizards-of-the-Ghosts.git"
  },
  "bugs": {
    "url": "https://github.com/Hmbown/Wizards-of-the-Ghosts/issues"
  },
  "keywords": [
    "hermes-agent",
    "ai-skills",
    "hermes-skills",
    "agents",
    "automation",
    "fantasy-rpg",
    "spells",
    "grimoire",
    "workflows"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "sync:canon": "node scripts/sync-canon.mjs",
    "expand:blueprints": "node scripts/expand-blueprints.mjs",
    "build:skills": "node scripts/render-skills.mjs",
    "export:linear": "node scripts/export-linear-seed.mjs",
    "dspy:validate": "./scripts/run_dspy_python.sh scripts/dspy_build_router.py --repo-root . --validate-only",
    "dspy:baseline": "./scripts/run_dspy_python.sh scripts/dspy_build_router.py --repo-root . --baseline-only && ./scripts/run_dspy_python.sh scripts/dspy_eval_router.py --repo-root . --baseline-only",
    "dspy:compile": "./scripts/run_dspy_python.sh scripts/dspy_build_router.py --repo-root .",
    "dspy:eval": "./scripts/run_dspy_python.sh scripts/dspy_eval_router.py --repo-root . --dspy-only",
    "gepa:spell:bootstrap": "./scripts/run_dspy_python.sh scripts/gepa_optimize_spell.py --repo-root . --bootstrap-only",
    "gepa:spell:optimize": "./scripts/run_dspy_python.sh scripts/gepa_optimize_spell.py --repo-root .",
    "gepa:spell:eval": "./scripts/run_dspy_python.sh scripts/gepa_eval_spell.py --repo-root .",
    "gepa:spell:promote": "./scripts/run_dspy_python.sh scripts/gepa_promote_spell.py --repo-root .",
    "wizard:install": "npm run build:skills && HERMES_HOME=$PWD/.hermes node scripts/install-hermes-skills.mjs && CODEX_HOME=$PWD/.codex node scripts/install-codex-skills.mjs",
    "verify": "node scripts/verify-release.mjs",
    "release:check": "npm run expand:blueprints && npm run build:skills && npm run export:linear && npm run verify",
    "install:codex-skills": "node scripts/install-codex-skills.mjs",
    "install:hermes-skills": "node scripts/install-hermes-skills.mjs",
    "bootstrap": "node scripts/sync-canon.mjs && node scripts/expand-blueprints.mjs && node scripts/render-skills.mjs && node scripts/export-linear-seed.mjs"
  }
}
